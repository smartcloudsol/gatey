{
  "name": "@smart-cloud/gatey-core",
  "version": "2.2.9",
  "description": "Login & SSO with Amazon Cognito",
  "author": "Smart Cloud Solutions Inc.",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "yarn build:js && yarn build:types",
    "build:js": "tsup --minify",
    "build:types": "tsc -p tsconfig.types.json",
    "lint": "eslint 'src/**/*.ts' --report-unused-disable-directives --max-warnings 0",
    "test": "echo \"Error: no test specified\" && exit 1",
    "publish": "WPSUITE_PREMIUM=true yarn build && npm publish --access=public"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "scope": "@smart-cloud/gatey-core"
  },
  "dependencies": {
    "@smart-cloud/wpsuite-core": "^2.2.11"
  },
  "peerDependencies": {
    "@aws-amplify/ui-react": "^6.15.0",
    "@wordpress/data": "^10.44.0",
    "aws-amplify": "^6.16.4"
  },
  "devDependencies": {
    "@aws-amplify/ui-react": "^6.15.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@wordpress/data": "^10.44.0",
    "aws-amplify": "^6.16.4",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
