{
  "name": "@smart-cloud/gatey-main",
  "version": "2.2.5",
  "type": "module",
  "license": "ISC",
  "scripts": {
    "build": "yarn build:js && yarn build:types",
    "build:js": "tsup --minify",
    "build:types": "tsc -p tsconfig.types.json",
    "lint": "eslint 'src/**/*.{ts,tsx}' --report-unused-disable-directives --max-warnings 0",
    "build-wp": "wp-scripts build --config=webpack.config.cjs --webpack-copy-php --output-path",
    "format": "wp-scripts format",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "packages-update": "wp-scripts packages-update",
    "plugin-zip": "wp-scripts plugin-zip",
    "start": "wp-scripts start --webpack-copy-php --output-path",
    "check-licenses": "wp-scripts check-licenses --prod"
  },
  "dependencies": {
    "@smart-cloud/gatey-core": "^2.2.9",
    "@smart-cloud/wpsuite-core": "^2.2.11"
  },
  "peerDependencies": {
    "@aws-amplify/ui-react": "^6.15.0",
    "@wordpress/data": "^10.44.0",
    "aws-amplify": "^6.16.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@aws-amplify/ui-react": "^6.15.0",
    "@eslint/js": "^10.0.1",
    "@types/jquery": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@wordpress/data": "^10.44.0",
    "@wordpress/scripts": "^32.0.0",
    "ajv": "^8.18.0",
    "aws-amplify": "^6.16.4",
    "country-data-list": "^1.6.2",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jquery": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
